XCHAT_VENDOR_ADMIN_EMAIL=admin@xchat.local
XCHAT_VENDOR_ADMIN_PASSWORD=change-me-demo-admin

# Optional image tag override. Keep latest for quick tests, or set a release tag such as v1.2.3.
XCHAT_IMAGE_TAG=latest

# Default Windows VM mode: no external backend required.
XCHAT_API_MODE=mock
XCHAT_PERSISTENCE_PROVIDER=local
XCHAT_REALTIME_CARRIER=local

# Optional external Supabase mode.
# Switch the three values above to the settings below and fill the Supabase values.
# XCHAT_API_MODE=real
# XCHAT_PERSISTENCE_PROVIDER=supabase
# XCHAT_REALTIME_CARRIER=supabase
# XCHAT_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# XCHAT_SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY
# XCHAT_SUPABASE_AUTH_REDIRECT_URL=http://YOUR_VM_HOST:8080

# Optional BIL integration.
# XCHAT_BIL_ENABLED=false
# XCHAT_BIL_BASE_URL=
# XCHAT_BIL_API_KEY=
# XCHAT_BIL_NETWORK=
# XCHAT_BIL_PARTICIPANT_ID=
# XCHAT_BIL_LEDGER_ID=
