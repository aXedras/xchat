# Realtime transport
VITE_REALTIME_CARRIER=supabase
VITE_REALTIME_CHANNEL=xchat-realtime
VITE_REALTIME_EVENT=message

# Persistence provider
VITE_PERSISTENCE_PROVIDER=supabase

# Supabase project credentials
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
VITE_SUPABASE_AUTH_REDIRECT_URL=http://127.0.0.1:4173

# Demo login for local and CI scenarios
VITE_DEMO_EMAIL=demo@axedras.com
VITE_DEMO_PASSWORD=password

# Optional websocket endpoint when carrier=websocket
VITE_WS_URL=ws://localhost:8080/ws
